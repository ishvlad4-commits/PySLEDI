# SLEDI Configuration
# Edit these values for your deployment

# Flask Secret Key (generate a secure random key)
FLASK_SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET_KEY

# Master key for admin API (CHANGE THIS!)
MASTER_KEY=CHANGE_ME_TO_YOUR_MASTER_KEY

# Database URL (Railway/Hetzner will set this automatically)
# Example: postgres://user:pass@host:5432/dbname
# Example: sqlite:///vigilance.db
DATABASE_URL=sqlite:///vigilance.db

# Server URL (for redirects, links in emails, etc.)
# Example: https://your-app.railway.app
SERVER_URL=https://CHANGE_ME.railway.app
